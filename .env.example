# ==============================
# Application
# ==============================
APP_NAME="Estimation Immobilier Bordeaux"
APP_BASE_URL="https://estimation-immobilier-bordeaux.fr"
WEBSITE_ID=1

# ==============================
# Base de données (MySQL / MariaDB)
# ==============================
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="estimation_immobilier_bordeaux"
DB_USER="root"
DB_PASS=""
DB_CHARSET="utf8mb4"

# ==============================
# Admin
# ==============================
ADMIN_EMAIL="contact@estimation-immobilier-bordeaux.fr"
ADMIN_PASSWORD=""

# ==============================
# Perplexity AI
# ==============================
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
PERPLEXITY_ENDPOINT="https://api.perplexity.ai/chat/completions"

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ENDPOINT="https://api.openai.com/v1/chat/completions"

# ==============================
# Email / SMTP
# ==============================
MAIL_FROM="no-reply@estimation-immobilier-bordeaux.fr"
MAIL_FROM_NAME="Estimation Immobilier Bordeaux"
MAIL_SMTP_HOST=""
MAIL_SMTP_PORT="587"
MAIL_SMTP_USER=""
MAIL_SMTP_PASS=""
MAIL_SMTP_ENCRYPTION="tls"

# ==============================
# Couleurs du site
# ==============================
SITE_COLOR_BG="#faf9f7"
SITE_COLOR_SURFACE="#ffffff"
SITE_COLOR_TEXT="#1a1410"
SITE_COLOR_MUTED="#6b6459"
SITE_COLOR_PRIMARY="#8B1538"
SITE_COLOR_PRIMARY_DARK="#6b0f2d"
SITE_COLOR_ACCENT="#D4AF37"
SITE_COLOR_ACCENT_LIGHT="#E8C547"
SITE_COLOR_BORDER="#e8dfd7"
SITE_COLOR_SUCCESS="#22c55e"
SITE_COLOR_WARNING="#f97316"
SITE_COLOR_DANGER="#e24b4a"
SITE_COLOR_INFO="#3b82f6"
SITE_COLOR_NEUTRAL="#000000"

# ==============================
# Maintenance
# ==============================
MAINTENANCE_MODE=false
MAINTENANCE_RETRY_AFTER=3600
